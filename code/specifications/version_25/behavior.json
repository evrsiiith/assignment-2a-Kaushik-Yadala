{
  "behaviors": [
    {
      "id": "DropSphereBehavior",
      "event": "OnCondition",
      "actors": ["sphere"],
      "precondition": {
        "all": [
          { "equals": ["Self.state", "floating"] },
          { "runAlgorithm": "IsObjectClicked", "params": { "obj": "Self" } }
        ]
      },
      "action": {
        "runAlgorithm": "DropSphere",
        "params": { "obj": "Self" }
      }
    },
    {
      "id": "ToggleCubeToRed",
      "event": "OnCondition",
      "actors": ["color_cube"],
      "precondition": {
        "all": [
          { "equals": ["Self.state", "green"] },
          { "runAlgorithm": "IsObjectClicked", "params": { "obj": "Self" } }
        ]
      },
      "action": {
        "runAlgorithm": "SetColorRed",
        "params": { "obj": "Self" }
      }
    },
    {
      "id": "ToggleCubeToGreen",
      "event": "OnCondition",
      "actors": ["color_cube"],
      "precondition": {
        "all": [
          { "equals": ["Self.state", "red"] },
          { "runAlgorithm": "IsObjectClicked", "params": { "obj": "Self" } }
        ]
      },
      "action": {
        "runAlgorithm": "SetColorGreen",
        "params": { "obj": "Self" }
      }
    },
    {
      "id": "InitializeCubeColor",
      "event": "OnCondition",
      "actors": ["color_cube"],
      "precondition": {
        "runAlgorithm": "NeedsInitialization",
        "params": { "obj": "Self" }
      },
      "action": {
        "runAlgorithm": "SetColorGreen",
        "params": { "obj": "Self" }
      }
    }
  ]
}
